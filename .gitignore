# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
*.egg

# =============================================================================
# Virtual environments
# =============================================================================
.venv/
venv/
env/
ENV/
.conda/

# =============================================================================
# Environment / secrets
# =============================================================================
.env
.env.*
*.pem
*.key

# =============================================================================
# IDEs
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# =============================================================================
# Testing & coverage
# =============================================================================
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.coveragerc

# =============================================================================
# Type checking
# =============================================================================
.mypy_cache/
.dmypy.json

# =============================================================================
# Logs
# =============================================================================
logs/*.log
logs/*.json
!logs/.gitkeep

# =============================================================================
# Output artefacts (keep directory structure, ignore content files)
# =============================================================================
output/mcdm/weights/*.csv
output/mcdm/weights/*.parquet
output/mcdm/rankings/*.csv
output/mcdm/rankings/*.parquet
output/mcdm/analysis/*.csv
output/mcdm/analysis/*.json
output/ml/imputed/*.parquet
output/ml/imputed/*.csv
output/ml/forecasts/*.csv
output/ml/forecasts/*.parquet
output/ml/shap/*.parquet
output/ml/shap/*.json
output/figures/**/*.png
output/figures/**/*.pdf
output/reports/*.html
output/reports/*.pdf
!output/**/.gitkeep

# =============================================================================
# AutoGluon model artifacts
# =============================================================================
AutogluonModels/
ag_models/
*.ag

# =============================================================================
# Jupyter (not used, but guard against accidental creation)
# =============================================================================
.ipynb_checkpoints/
*.ipynb

# =============================================================================
# Temporary / scratch
# =============================================================================
tmp/
scratch/
*.tmp
*.bak
